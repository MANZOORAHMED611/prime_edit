{
  "name": "Objective-C++",
  "keywords": ["auto", "break", "case", "char", "class", "const", "constexpr", "continue", "default", "delete", "do", "double", "else", "enum", "explicit", "extern", "false", "float", "for", "friend", "goto", "if", "inline", "int", "long", "mutable", "namespace", "new", "noexcept", "nullptr", "operator", "private", "protected", "public", "register", "return", "short", "signed", "sizeof", "static", "static_assert", "static_cast", "struct", "switch", "template", "this", "thread_local", "throw", "true", "try", "typedef", "typeid", "typename", "union", "unsigned", "using", "virtual", "void", "volatile", "wchar_t", "while", "override", "final", "@interface", "@implementation", "@protocol", "@end", "@private", "@protected", "@public", "@property", "@synthesize", "@dynamic", "@optional", "@required", "@try", "@catch", "@finally", "@throw", "@selector", "@encode", "@synchronized", "@autoreleasepool", "@class", "self", "super", "nil", "YES", "NO", "id", "BOOL", "instancetype"],
  "types": ["NSObject", "NSString", "NSArray", "NSDictionary", "NSSet", "NSNumber", "NSInteger", "NSUInteger", "CGFloat", "string", "vector", "map", "set", "unique_ptr", "shared_ptr"],
  "builtins": ["NSLog", "NSAssert"],
  "singleLineComment": "//",
  "multiLineCommentStart": "/*",
  "multiLineCommentEnd": "*/",
  "stringDelimiters": ["\"", "'"],
  "preprocessorPrefix": "#",
  "numberPattern": "\\b[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?[fFlLuU]*\\b|\\b0[xX][0-9a-fA-F]+\\b",
  "functionPattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
  "foldBased": "brace"
}
