{
  "name": "Java",
  "keywords": ["abstract", "assert", "break", "case", "catch", "class", "const", "continue", "default", "do", "else", "enum", "extends", "final", "finally", "for", "goto", "if", "implements", "import", "instanceof", "interface", "native", "new", "package", "private", "protected", "public", "return", "static", "strictfp", "super", "switch", "synchronized", "this", "throw", "throws", "transient", "try", "void", "volatile", "while", "true", "false", "null", "var", "record", "sealed", "permits", "yield", "non-sealed"],
  "types": ["int", "long", "short", "byte", "float", "double", "boolean", "char", "String", "Object", "List", "Map", "Set", "Array", "Integer", "Long", "Double", "Boolean", "Float", "Short", "Byte", "Character", "Void", "ArrayList", "HashMap", "HashSet", "LinkedList", "TreeMap", "TreeSet", "Optional", "Stream", "Collection", "Iterable", "Iterator", "Comparable", "Runnable", "Callable", "Future"],
  "builtins": ["System", "Math", "Thread", "Runtime", "Class", "ClassLoader", "StringBuilder", "StringBuffer", "Arrays", "Collections", "Objects"],
  "singleLineComment": "//",
  "multiLineCommentStart": "/*",
  "multiLineCommentEnd": "*/",
  "stringDelimiters": ["\"", "'"],
  "preprocessorPrefix": "@",
  "numberPattern": "\\b[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?[fFdDlL]?\\b|\\b0[xX][0-9a-fA-F]+[lL]?\\b|\\b0[bB][01]+[lL]?\\b",
  "functionPattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
  "foldBased": "brace"
}
