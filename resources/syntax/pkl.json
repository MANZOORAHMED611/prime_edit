{
  "name": "Pkl",
  "keywords": ["module", "import", "amends", "extends", "class", "typealias", "function", "let", "const", "fixed", "hidden", "local", "abstract", "open", "external", "for", "when", "if", "else", "is", "as", "in", "new", "this", "outer", "super", "throw", "trace", "read", "true", "false", "null", "nothing", "unknown"],
  "types": ["String", "Boolean", "Int", "Float", "Number", "Duration", "DataSize", "Pair", "Collection", "List", "Set", "Map", "Listing", "Mapping", "Dynamic", "Typed", "Any", "Module", "Class", "TypeAlias", "Null", "Void", "Regex", "Uri", "IntSeq"],
  "builtins": ["print", "trace", "throw", "import", "read", "log", "base", "math", "reflect"],
  "singleLineComment": "//",
  "multiLineCommentStart": "/*",
  "multiLineCommentEnd": "*/",
  "stringDelimiters": ["\""],
  "numberPattern": "\\b[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?\\b|\\b0[xX][0-9a-fA-F]+\\b|\\b0[bB][01]+\\b|\\b0[oO][0-7]+\\b",
  "functionPattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
  "functionRegex": "^\\s*(?:function|class|typealias)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
  "variablePattern": "\\$\\([^)]+\\)",
  "foldBased": "brace"
}
