{
  "name": "Jsonnet",
  "keywords": ["local", "if", "then", "else", "for", "in", "import", "importstr", "importbin", "function", "self", "super", "error", "assert", "true", "false", "null", "tailstrict"],
  "types": [],
  "builtins": ["std"],
  "singleLineComment": "//",
  "multiLineCommentStart": "/*",
  "multiLineCommentEnd": "*/",
  "stringDelimiters": ["\"", "'"],
  "numberPattern": "\\b[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?\\b|\\b0[xX][0-9a-fA-F]+\\b",
  "functionPattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
  "keyPattern": "\"[^\"]*\"\\s*:|[a-zA-Z_][a-zA-Z0-9_]*\\s*(?=:)",
  "foldBased": "brace"
}
