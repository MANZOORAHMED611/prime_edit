  "builtins": ["abs", "append", "apply", "assoc", "assq", "assv", "boolean?", "car", "cdr", "caar", "cadr", "cdar", "cddr", "ceiling", "char?", "char->integer", "close-input-port", "close-output-port", "cons", "display", "eof-object?", "eq?", "equal?", "eqv?", "error", "even?", "exact", "exact?", "expt", "floor", "for-each", "gcd", "inexact", "inexact?", "integer?", "integer->char", "length", "list", "list?", "list-ref", "list-tail", "map", "max", "member", "memq", "memv", "min", "modulo", "negative?", "newline", "not", "null?", "number?", "number->string", "odd?", "open-input-file", "open-output-file", "pair?", "positive?", "procedure?", "quotient", "rational?", "read", "real?", "remainder", "reverse", "round", "string?", "string->number", "string->symbol", "string-append", "string-length", "string-ref", "substring", "symbol?", "symbol->string", "truncate", "values", "vector?", "vector-length", "vector-ref", "vector-set!", "write", "zero?"],
