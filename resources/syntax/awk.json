{
  "name": "Awk",
  "keywords": ["BEGIN", "END", "BEGINFILE", "ENDFILE", "if", "else", "while", "for", "do", "break", "continue", "function", "return", "delete", "exit", "next", "nextfile", "getline", "print", "printf", "sprintf", "in"],
  "types": [],
  "builtins": ["atan2", "cos", "sin", "exp", "log", "sqrt", "int", "rand", "srand", "gsub", "index", "length", "match", "split", "sprintf", "sub", "substr", "tolower", "toupper", "close", "fflush", "system", "mktime", "strftime", "systime", "gensub", "patsplit"],
  "singleLineComment": "#",
  "multiLineCommentStart": "",
  "multiLineCommentEnd": "",
  "stringDelimiters": ["\""],
  "numberPattern": "\\b[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?\\b|\\b0[xX][0-9a-fA-F]+\\b",
  "functionPattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
  "functionRegex": "^\\s*function\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
  "variablePattern": "\\$[0-9]+|\\b(NR|NF|FS|RS|OFS|ORS|FILENAME|FNR|RSTART|RLENGTH|SUBSEP|ARGC|ARGV|ENVIRON|CONVFMT|OFMT)\\b"
}
