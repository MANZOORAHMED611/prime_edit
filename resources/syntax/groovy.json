{
  "name": "Groovy",
  "keywords": ["abstract", "as", "assert", "break", "case", "catch", "class", "const", "continue", "def", "default", "do", "else", "enum", "extends", "false", "final", "finally", "for", "goto", "if", "implements", "import", "in", "instanceof", "interface", "native", "new", "null", "package", "private", "protected", "public", "return", "static", "strictfp", "super", "switch", "synchronized", "this", "throw", "throws", "trait", "transient", "true", "try", "var", "void", "volatile", "while"],
  "types": ["boolean", "byte", "char", "double", "float", "int", "long", "short", "String", "Object", "List", "Map", "Set", "Array", "Integer", "Long", "Double", "Boolean", "BigDecimal", "BigInteger", "Closure", "GString", "Range"],
  "builtins": ["println", "print", "printf", "each", "eachWithIndex", "collect", "find", "findAll", "any", "every", "sort", "unique", "groupBy", "inject", "with", "identity", "tap"],
  "singleLineComment": "//",
  "multiLineCommentStart": "/*",
  "multiLineCommentEnd": "*/",
  "stringDelimiters": ["\"", "'"],
  "preprocessorPrefix": "@",
  "numberPattern": "\\b[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?[gGfFdDlLiI]?\\b|\\b0[xX][0-9a-fA-F]+\\b",
  "functionPattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
  "foldBased": "brace"
}
