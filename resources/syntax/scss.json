{
  "name": "SCSS",
  "keywords": ["import", "extend", "include", "mixin", "function", "return", "if", "else", "for", "each", "while", "at-root", "warn", "error", "debug", "use", "forward", "content", "important"],
  "types": [],
  "builtins": ["rgb", "rgba", "hsl", "hsla", "calc", "var", "url", "linear-gradient", "radial-gradient", "min", "max", "clamp", "darken", "lighten", "saturate", "desaturate", "mix", "adjust-hue", "complement", "invert", "opacify", "transparentize", "percentage", "round", "ceil", "floor", "abs", "length", "nth", "join", "append", "map-get", "map-merge", "map-keys", "map-values"],
  "singleLineComment": "//",
  "multiLineCommentStart": "/*",
  "multiLineCommentEnd": "*/",
  "stringDelimiters": ["\"", "'"],
  "numberPattern": "\\b[0-9]+(\\.[0-9]*)?(px|em|rem|%|vh|vw|vmin|vmax|pt|deg|rad|s|ms)?\\b|#[0-9A-Fa-f]{3,8}\\b",
  "functionPattern": "\\b([a-zA-Z_-][a-zA-Z0-9_-]*)\\s*\\(",
  "variablePattern": "\\$[A-Za-z_-][A-Za-z0-9_-]*",
  "foldBased": "brace"
}
