{
  "name": "Clojure",
  "keywords": ["def", "defn", "defmacro", "defonce", "defmulti", "defmethod", "defprotocol", "defrecord", "deftype", "defstruct", "fn", "let", "loop", "recur", "do", "if", "if-not", "if-let", "when", "when-not", "when-let", "when-first", "cond", "condp", "case", "and", "or", "not", "try", "catch", "finally", "throw", "monitor-enter", "monitor-exit", "quote", "var", "set!", "new", "import", "use", "require", "ns", "in-ns", "refer", "for", "doseq", "dotimes", "while", "true", "false", "nil"],
  "types": ["Atom", "Ref", "Agent", "Var", "Keyword", "Symbol", "List", "Vector", "Map", "Set", "Seq", "LazySeq", "String", "Integer", "Long", "Double", "Float", "Boolean", "Character", "Ratio", "BigDecimal", "BigInteger"],
  "builtins": ["println", "print", "prn", "pr", "str", "format", "read", "read-string", "eval", "apply", "map", "filter", "reduce", "first", "rest", "cons", "conj", "assoc", "dissoc", "get", "get-in", "assoc-in", "update-in", "merge", "keys", "vals", "seq", "count", "empty?", "nil?", "some?", "every?", "some", "comp", "partial", "identity", "constantly", "complement", "juxt", "memoize", "atom", "deref", "reset!", "swap!", "compare-and-set!", "add-watch", "remove-watch"],
  "singleLineComment": ";",
  "multiLineCommentStart": "",
  "multiLineCommentEnd": "",
  "stringDelimiters": ["\""],
  "numberPattern": "\\b[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?[MN]?\\b|\\b0[xX][0-9a-fA-F]+\\b|\\b[0-9]+r[0-9a-zA-Z]+\\b|[0-9]+/[0-9]+",
  "functionPattern": "\\(([a-zA-Z_!?*+<>=.-][a-zA-Z0-9_!?*+<>=.-]*)",
  "foldBased": "paren"
}
