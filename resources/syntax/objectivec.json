{
  "name": "Objective-C",
  "keywords": ["auto", "break", "case", "char", "const", "continue", "default", "do", "double", "else", "enum", "extern", "float", "for", "goto", "if", "inline", "int", "long", "register", "restrict", "return", "short", "signed", "sizeof", "static", "struct", "switch", "typedef", "union", "unsigned", "void", "volatile", "while", "@interface", "@implementation", "@protocol", "@end", "@private", "@protected", "@public", "@package", "@property", "@synthesize", "@dynamic", "@optional", "@required", "@try", "@catch", "@finally", "@throw", "@selector", "@encode", "@synchronized", "@autoreleasepool", "@class", "@compatibility_alias", "@defs", "self", "super", "nil", "Nil", "YES", "NO", "true", "false", "id", "Class", "SEL", "IMP", "BOOL", "instancetype", "in", "out", "inout", "bycopy", "byref", "oneway"],
  "types": ["NSObject", "NSString", "NSMutableString", "NSArray", "NSMutableArray", "NSDictionary", "NSMutableDictionary", "NSSet", "NSMutableSet", "NSNumber", "NSInteger", "NSUInteger", "CGFloat", "NSData", "NSDate", "NSURL", "NSError", "NSNotification", "NSBundle", "NSUserDefaults", "NSFileManager", "NSThread", "NSTimer", "NSIndexPath", "NSRange", "CGRect", "CGSize", "CGPoint", "UIView", "UIViewController", "UILabel", "UIButton", "UIImage", "UIImageView", "UITableView", "UICollectionView"],
  "builtins": ["NSLog", "NSAssert", "NSStringFromClass", "NSClassFromString", "NSStringFromSelector", "NSSelectorFromString"],
  "singleLineComment": "//",
  "multiLineCommentStart": "/*",
  "multiLineCommentEnd": "*/",
  "stringDelimiters": ["\"", "'"],
  "preprocessorPrefix": "#",
  "numberPattern": "\\b[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?[fFlL]?\\b|\\b0[xX][0-9a-fA-F]+\\b",
  "functionPattern": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*[\\(\\[]",
  "foldBased": "brace"
}
