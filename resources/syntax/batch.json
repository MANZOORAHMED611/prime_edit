{
  "name": "Batch",
  "keywords": ["echo", "set", "if", "else", "for", "in", "do", "goto", "call", "exit", "pause", "rem", "cls", "copy", "del", "dir", "move", "ren", "type", "mkdir", "rmdir", "cd", "pushd", "popd", "start", "title", "color", "mode", "prompt", "path", "errorlevel", "defined", "exist", "not", "equ", "neq", "lss", "leq", "gtr", "geq", "enabledelayedexpansion", "setlocal", "endlocal", "shift", "choice", "findstr", "taskkill", "tasklist", "timeout", "where", "reg", "net", "sc", "wmic", "icacls", "attrib"],
  "types": [],
  "builtins": ["nul", "con", "prn", "aux", "com1", "lpt1", "on", "off"],
  "caseInsensitiveKeywords": true,
  "singleLineComment": "",
  "multiLineCommentStart": "",
  "multiLineCommentEnd": "",
  "stringDelimiters": ["\""],
  "numberPattern": "\\b[0-9]+\\b",
  "functionPattern": "",
  "variablePattern": "%[~a-zA-Z0-9_]+%?|![a-zA-Z0-9_]+!",
  "keyPattern": "^\\s*:[a-zA-Z_][a-zA-Z0-9_]*"
}
