{
  "name": "PHP",
  "keywords": ["abstract", "and", "as", "break", "callable", "case", "catch", "class", "clone", "const", "continue", "declare", "default", "do", "else", "elseif", "enddeclare", "endfor", "endforeach", "endif", "endswitch", "endwhile", "extends", "final", "finally", "fn", "for", "foreach", "function", "global", "goto", "if", "implements", "include", "include_once", "instanceof", "insteadof", "interface", "match", "namespace", "new", "or", "print", "private", "protected", "public", "readonly", "require", "require_once", "return", "static", "switch", "throw", "trait", "try", "use", "var", "while", "xor", "yield", "true", "false", "null", "enum"],
  "types": ["int", "float", "string", "bool", "array", "object", "void", "never", "mixed", "null", "self", "parent", "iterable", "callable"],
  "builtins": ["echo", "isset", "unset", "empty", "die", "exit", "list", "array_push", "array_pop", "array_shift", "array_unshift", "array_merge", "array_map", "array_filter", "array_reduce", "array_keys", "array_values", "count", "strlen", "strpos", "substr", "str_replace", "implode", "explode", "trim", "strtolower", "strtoupper", "sprintf", "printf", "json_encode", "json_decode", "var_dump", "print_r"],
